# ════════════════════════════════════════
# StreamMalin V2 — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ════════════════════════════════════════

# Base de données (SQLite par défaut, PostgreSQL en prod)
DATABASE_URL="file:./dev.db"
# Pour PostgreSQL : DATABASE_URL="postgresql://user:password@localhost:5432/streammalin"

# Telegram — Notifications Admin
TELEGRAM_BOT_TOKEN="votre_token_bot_telegram"
TELEGRAM_ADMIN_CHAT_ID="votre_chat_id_telegram"

# Token d'administration (pour confirmer les paiements)
ADMIN_SECRET_TOKEN="changez-ce-token-en-production-avec-openssl-rand-hex-32"

# URL de base de l'application
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# En production : NEXT_PUBLIC_BASE_URL="https://streammalin.fr"

# Adresses Crypto (affichées dans le checkout)
NEXT_PUBLIC_WALLET_SOL="8aUZeioqmxWJMf6Lfa6BCbv3dCQpMU7KxoQHPwT1Mz9e"
NEXT_PUBLIC_WALLET_XRP="rPLwSnrUEMZaiV6zZW2gvcgNbtk6ASt3it"
NEXT_PUBLIC_WALLET_USDT_TRC20="TDN6Jd12G9AoJfD9b46SEThEjKsXzBGUVR"

# PayPal — Lien de paiement (sera complété avec [MONTANT])
NEXT_PUBLIC_PAYPAL_ME_BASE="https://www.paypal.com/paypalme/AccesPremium89"

# Resend — Envoi d'emails transactionnels (contact@streammalin.fr)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ADMIN_EMAIL="oub9493@gmail.com"

# Vercel Cron — Secret pour protéger /api/admin/send-reminders (auto-généré par Vercel)
CRON_SECRET="votre_cron_secret_vercel"
